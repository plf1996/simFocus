# simFocus Backend Environment Configuration
# Copy this file to .env and configure your settings

# =============================================================================
# Application Settings
# =============================================================================
APP_NAME=simFocus
APP_VERSION=0.1.0
APP_ENV=development  # development | testing | production
DEBUG=true
API_V1_PREFIX=/api/v1
PROJECT_ROOT=/root/projects/simFocus

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1

# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=simfocus
DATABASE_PASSWORD=simfocus_password
DATABASE_NAME=simfocus
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600
DATABASE_ECHO=false

# =============================================================================
# Security Settings
# =============================================================================
# IMPORTANT: Generate a strong secret key for production
# Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-in-production

# IMPORTANT: Generate encryption key for AES-256 (32 bytes, base64 encoded)
# Use: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY=

# =============================================================================
# JWT Configuration
# =============================================================================
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# CORS Settings
# =============================================================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# =============================================================================
# External API Settings
# =============================================================================
# Optional: Server-side default API keys (users can also provide their own)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
API_TIMEOUT=120
API_MAX_RETRIES=3
API_RETRY_DELAY=1.0

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=100

# =============================================================================
# Discussion Settings
# =============================================================================
DEFAULT_DISCUSSION_ROUNDS=10
MAX_DISCUSSION_ROUNDS=20
MIN_DISCUSSION_ROUNDS=3
DISCUSSION_TIMEOUT_SECONDS=300

# =============================================================================
# File Upload Settings
# =============================================================================
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_EXTENSIONS=pdf,txt,md,json
UPLOAD_DIR=/tmp/simfocus/uploads

# =============================================================================
# Logging Settings
# =============================================================================
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json  # json | text
LOG_FILE=

# =============================================================================
# Pagination Settings
# =============================================================================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
